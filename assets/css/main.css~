i {
  font-style: normal;
}

body {
  background: linear-gradient(180deg, #000814 0%, #001d3d 100%);
  min-height: 100vh;
  color: #d9d9d9;
}

h1, h2, h3 {
  color: #ffd60a;
}

footer {
  width: 100%;
  max-width: 960px;
  margin: 0 auto;
}
footer nav ul {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  border-bottom: 1px solid #4a4a4a;
  padding-bottom: 1rem;
  margin-bottom: 1rem;
}
footer .nav-link {
  color: #d9d9d9;
}
footer .nav-link:hover {
  color: #ffd60a;
}
footer p {
  color: #4a4a4a;
}

.card__icon {
  font-size: 40px;
  color: #ffd60a;
  background-color: #003566;
}

.weather-card {
  background-color: #001d3d;
  border: 1px solid #4a4a4a;
  color: #d9d9d9;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.weather-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 6px 16px rgba(255, 214, 10, 0.2);
}
.weather-card .card-title {
  color: #ffd60a;
  font-size: 1.25rem;
}
.weather-card .card-text {
  color: #d9d9d9;
}
.weather-card .card-link {
  color: #ffc300;
}
.weather-card .card-link:hover {
  color: #ffd60a;
}

.navbar {
  background-color: #000814 !important;
  border-bottom: 2px solid #ffd60a;
}
.navbar .navbar-brand {
  color: #ffd60a;
  font-weight: bold;
}
.navbar .navbar-brand:hover {
  color: #ffc300;
}
.navbar .nav-link {
  color: #d9d9d9;
}
.navbar .nav-link:hover, .navbar .nav-link.active {
  color: #ffd60a;
}
.navbar .navbar-toggler {
  border-color: #ffd60a;
}

.card {
  background-color: #001d3d;
  border: 1px solid #4a4a4a;
  color: #d9d9d9;
}
.card .card-title {
  color: #ffd60a;
}
.card .list-group-item {
  background-color: #001d3d;
  color: #d9d9d9;
  border-color: #4a4a4a;
}
.card .list-group-item i {
  color: #ffd60a;
}
.card .text-body-secondary {
  color: #4a4a4a !important;
}

